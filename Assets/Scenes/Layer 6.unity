  m_Script: {fileID: 11500000, guid: 54031af347cb0aa49a18f356606d6e66, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::EndDialogue
  dialoguePanel: {fileID: 561733611}
  dialogueText: {fileID: 1047537987}
  lines:
  - You've carved your way through the dungeons of hell.
  - You silenced the monsters and demon that roam this forsaken plane.
  - Even Satan himself lies defeated.
  - For your triumph, you are rewarded with the throne of the Hollow King.
  - The Throne, however, is no reward. It is a curse.
  - 'The Corruption of the Throne seeps into your flesh, blood and bones. '
  - 'Your will is twisted, your humanity is consumed. '
  - You became the very thing you sworn to destroy.
  - The cycle continues.....
  - Thanks For Playing!
  typingSpeed: 0.05
  delayBetweenLines: 3
